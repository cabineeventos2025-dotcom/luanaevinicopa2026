# =====================================================
# Luana Queiroz e Família — Copa 2026
# Variáveis de Ambiente
# =====================================================

# --- football-data.org ---
# Obtenha sua chave gratuita em: https://www.football-data.org/
VITE_FOOTBALL_DATA_API_URL=https://api.football-data.org/v4
VITE_FOOTBALL_DATA_API_KEY=SUA_CHAVE_AQUI
VITE_WORLD_CUP_COMPETITION_CODE=WC
VITE_WORLD_CUP_SEASON=2026

# --- Supabase ---
# Crie seu projeto em: https://supabase.com/
# Se não configurado, o sistema usará LocalStorage como fallback.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Admin ---
# Senha para acessar o painel administrativo em /admin
VITE_ADMIN_PASSWORD=admin2026

# =====================================================
# INSTRUÇÕES DE DEPLOY NA VERCEL
# =====================================================
# 1. Crie um projeto na Vercel e conecte este repositório.
# 2. Vá em Settings > Environment Variables e adicione todas as
#    variáveis acima com seus valores reais.
# 3. Deploy!
#
# IMPORTANTE: Nunca commite o arquivo .env com valores reais.
# Use apenas este .env.example como referência.
